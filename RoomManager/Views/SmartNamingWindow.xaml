<Window x:Class="RoomManager.Views.SmartNamingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能命名建议" 
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="智能命名建议" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- 当前房间信息 -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="当前房间" FontSize="12" Foreground="#8E8E93"/>
                    <TextBlock x:Name="CurrentRoomName" Text="-" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="编号" FontSize="12" Foreground="#8E8E93"/>
                        <TextBlock x:Name="CurrentRoomNumber" Text="-" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="楼层" FontSize="12" Foreground="#8E8E93"/>
                        <TextBlock x:Name="CurrentRoomLevel" Text="-" FontSize="16"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="面积" FontSize="12" Foreground="#8E8E93"/>
                        <TextBlock x:Name="CurrentRoomArea" Text="-" FontSize="16"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 建议列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="命名建议" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ItemsControl Grid.Row="1" x:Name="SuggestionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F9F9FB" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding SuggestedName}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Reason}" FontSize="12" Foreground="#8E8E93" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- 置信度指示器 -->
                                        <Border Background="#34C759" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" 
                                                       FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                        
                                        <Button Content="应用" Style="{StaticResource ModernButton}" 
                                                Padding="12,6" FontSize="12"
                                                Click="OnApplySuggestion" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="刷新建议" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    Click="OnRefresh"/>
            <Button Content="关闭" Style="{StaticResource SecondaryButton}" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
