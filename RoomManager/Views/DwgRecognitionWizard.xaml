<Window x:Class="RoomManager.Views.DwgRecognitionWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:RoomManager.Utils"
        Title="从 DWG 识别房间" 
        Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <utils:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="从 DWG 识别房间" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="识别链接 DWG 中的房间名称并填充到 Revit 房间" 
                       FontSize="12" Foreground="#8E8E93" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 步骤区域 -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    x:Name="StepTabs">

            <!-- 步骤1: 选择图纸和图层 -->
            <TabItem Header="1. 选择图纸">
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CAD 链接列表 -->
                        <TextBlock Grid.Row="0" Text="选择链接的 CAD 图纸" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding CADLinks}" 
                                 SelectedItem="{Binding SelectedCADLink}"
                                 BorderThickness="1" BorderBrush="#E5E5EA">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#8E8E93" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 图层选择 -->
                        <TextBlock Grid.Row="2" Text="选择房间名文字所在的图层（可选，不选则搜索所有图层）" 
                                   FontSize="14" FontWeight="SemiBold" Margin="0,12,0,8"/>
                        <Border Grid.Row="3" BorderThickness="1" BorderBrush="#E5E5EA" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,4">
                                    <Button Content="全选" Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"
                                            Click="OnSelectAllLayers" Margin="0,0,4,0"/>
                                    <Button Content="全不选" Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"
                                            Click="OnDeselectAllLayers" Margin="0,0,4,0"/>
                                    <Button Content="扫描图层" Style="{StaticResource ModernButton}" Padding="8,3" FontSize="11"
                                            Click="OnScanLayers"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" x:Name="LayerListBox" SelectionMode="Multiple"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,6,0"
                                                          Checked="OnLayerCheckChanged" Unchecked="OnLayerCheckChanged"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                                <TextBlock Text="{Binding TextCount, StringFormat={} ({0} 个文字)}" 
                                                           FontSize="11" Foreground="#8E8E93" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- 选项 -->
                        <StackPanel Grid.Row="4" Margin="0,8,0,0">
                            <CheckBox Content="自动在无房间的闭合空间放置房间" IsChecked="{Binding AutoPlaceRooms}" 
                                      FontSize="12" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- 步骤2: 预览匹配结果 -->
            <TabItem Header="2. 预览结果" x:Name="ResultTab">
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="匹配结果" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MatchSummary" FontSize="12" Foreground="#8E8E93" 
                                       Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding MatchResults}"
                                  AutoGenerateColumns="False" IsReadOnly="False"
                                  BorderThickness="1" BorderBrush="#E5E5EA"
                                  GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#F9F9FB"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  x:Name="ResultGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="房间编号" Binding="{Binding RoomNumber}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="当前名称" Binding="{Binding RoomName}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="识别名称" Binding="{Binding MatchedText}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#007AFF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="置信度" Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="80" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="操作" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="选择" Padding="6,2" FontSize="11" Margin="0,0,4,0"
                                                        Click="OnManualSelect" Tag="{Binding}"/>
                                                <Button Content="清除" Padding="6,2" FontSize="11"
                                                        Click="OnClearMatch" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="2" x:Name="StatusText" FontSize="12" Foreground="#8E8E93" Margin="0,8,0,0"/>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="OnCancelClick" Margin="0,0,8,0"/>
            <Button Content="预览识别" Style="{StaticResource SecondaryButton}" Click="OnPreviewClick" Margin="0,0,8,0"/>
            <Button Content="确认并填充" Style="{StaticResource ModernButton}" Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
