<Window x:Class="RoomManager.Views.DwgPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DWG 识别预览" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="DWG 识别预览" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="MatchCountText" Text="已匹配: 0 / 0" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 预览图 -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="预览图" FontSize="12" Foreground="#8E8E93" Margin="0,-24,0,0" VerticalAlignment="Top"/>
                <Canvas x:Name="PreviewCanvas" Background="#F9F9FB"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="Blue" Opacity="0.6" Margin="0,0,4,0"/>
                    <TextBlock Text="DWG 文字" FontSize="11" Foreground="#8E8E93" Margin="0,0,16,0"/>
                    <Rectangle Width="8" Height="8" Fill="Green" Opacity="0.6" Margin="0,0,4,0"/>
                    <TextBlock Text="房间中心" FontSize="11" Foreground="#8E8E93"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 匹配列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="匹配结果" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="重新匹配" Style="{StaticResource SecondaryButton}" 
                            Padding="12,6" HorizontalAlignment="Right" Click="OnAutoMatch"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewItems}"
                          AutoGenerateColumns="False" IsReadOnly="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0" Background="Transparent"
                          RowBackground="White" AlternatingRowBackground="#F9F9FB">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="房间编号" Binding="{Binding RoomNumber}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="房间名称" Binding="{Binding RoomName}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="匹配文字" Binding="{Binding MatchedText}" Width="*"/>
                        <DataGridTextColumn Header="置信度" Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="70" IsReadOnly="True"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="操作" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="" ToolTip="手动编辑" Padding="8,4" Margin="0,0,4,0"
                                                Click="OnManualEdit" Tag="{Binding}"/>
                                        <Button Content="" ToolTip="清除匹配" Padding="8,4"
                                                Click="OnClearMatch" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    Click="OnCancel"/>
            <Button Content="确认应用" Style="{StaticResource ModernButton}"
                    Click="OnConfirm"/>
        </StackPanel>
    </Grid>
</Window>
