<Window x:Class="RoomManager.Views.ManualMatchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手动匹配" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 房间信息 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="房间" FontSize="12" Foreground="#8E8E93"/>
            <TextBlock x:Name="RoomInfoText" Text="-" FontSize="18" FontWeight="Bold"/>
        </StackPanel>

        <!-- 当前匹配 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="当前匹配" FontSize="12" Foreground="#8E8E93"/>
            <TextBlock x:Name="CurrentMatchText" Text="-" FontSize="14"/>
        </StackPanel>

        <!-- 搜索框 -->
        <TextBox Grid.Row="2" x:Name="SearchTextBox" 
                 Padding="12,8" FontSize="14" Margin="0,0,0,12"
                 TextChanged="OnSearchTextChanged">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="#F2F2F7" CornerRadius="8" Padding="12,8">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- 文字列表 -->
        <ListBox Grid.Row="3" x:Name="TextListBox" 
                 SelectionChanged="OnTextSelected"
                 BorderThickness="0" Background="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Content}" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="{Binding Position}" FontSize="11" Foreground="#8E8E93"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 预览 -->
        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock Text="预览" FontSize="12" Foreground="#8E8E93"/>
            <TextBlock x:Name="PreviewText" Text="-" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,16"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        Click="OnCancel"/>
                <Button Content="确认" Style="{StaticResource ModernButton}"
                        Click="OnConfirm"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
