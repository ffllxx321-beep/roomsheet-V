<Window x:Class="RoomManager.Views.ValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据校验" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="" FontSize="24" Margin="0,0,8,0"/>
            <TextBlock Text="数据校验报告" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- 统计概览 -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TotalRooms, StringFormat={}{0} 间}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="总房间数" FontSize="12" Foreground="#8E8E93"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding ValidRoomCount, StringFormat={}{0} 间}" FontSize="24" FontWeight="Bold" Foreground="#34C759"/>
                    <TextBlock Text="校验通过" FontSize="12" Foreground="#8E8E93"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding ErrorCount, StringFormat={}{0} 个}" FontSize="24" FontWeight="Bold" Foreground="#FF3B30"/>
                    <TextBlock Text="错误" FontSize="12" Foreground="#8E8E93"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="{Binding WarningCount, StringFormat={}{0} 个}" FontSize="24" FontWeight="Bold" Foreground="#FF9500"/>
                    <TextBlock Text="警告" FontSize="12" Foreground="#8E8E93"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 问题列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="问题详情" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding AllIssues}" AutoGenerateColumns="False"
                          BorderThickness="0" Background="Transparent" GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="房间 ID" Binding="{Binding RoomId}" Width="100"/>
                        <DataGridTextColumn Header="房间名称" Binding="{Binding RoomName}" Width="150"/>
                        <DataGridTextColumn Header="字段" Binding="{Binding FieldName}" Width="100"/>
                        <DataGridTemplateColumn Header="严重程度" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Severity}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                        <Setter Property="Foreground" Value="#FF3B30"/>
                                                        <Setter Property="Text" Value="错误"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#FF9500"/>
                                                        <Setter Property="Text" Value="警告"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="问题描述" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="导出报告" Style="{StaticResource ModernButton}" Margin="0,0,8,0"
                    Click="OnExportReport"/>
            <Button Content="关闭" Style="{StaticResource ModernButton}" Background="#E5E5EA" Foreground="#1C1C1E"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
