<Window x:Class="RoomManager.Views.BatchOperationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量操作" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批量操作" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- 操作选项卡 -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- 批量重命名 -->
            <TabItem Header="批量重命名">
                <Border Style="{StaticResource CardPanel}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="正则替换" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="查找模式：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="RegexPatternTextBox" 
                                     Text="办公室" Padding="8,6" FontSize="14"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="替换为：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="RegexReplacementTextBox" 
                                     Text="办公区" Padding="8,6" FontSize="14"/>
                        </Grid>

                        <TextBlock Text="前缀/后缀" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,12"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="前缀：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="PrefixTextBox" 
                                     Padding="8,6" FontSize="14"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="后缀：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="SuffixTextBox" 
                                     Padding="8,6" FontSize="14"/>
                        </Grid>

                        <CheckBox x:Name="RemoveExistingCheckBox" Content="移除现有前缀/后缀" Margin="0,8,0,0"/>

                        <Button Content="应用重命名" Style="{StaticResource ModernButton}" 
                                Margin="0,16,0,0" Click="OnApplyRename"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 批量编号 -->
            <TabItem Header="批量编号">
                <Border Style="{StaticResource CardPanel}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="自动编号" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="编号模板：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="NumberingTemplateTextBox" 
                                     Text="F{floor}-{index:00}" Padding="8,6" FontSize="14"/>
                        </Grid>

                        <TextBlock Text="可用变量: {floor} {index} {index:00} {index:000} {name}" 
                                   FontSize="11" Foreground="#8E8E93" Margin="0,4,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="起始编号" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="StartIndexTextBox" Text="1" Padding="8,6" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="步长" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="StepTextBox" Text="1" Padding="8,6" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="应用编号" Style="{StaticResource ModernButton}" 
                                Margin="0,16,0,0" Click="OnApplyNumbering"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 批量设置参数 -->
            <TabItem Header="设置参数">
                <Border Style="{StaticResource CardPanel}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="批量设置参数值" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="参数名称：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="ParameterNameTextBox" 
                                     Text="备注" Padding="8,6" FontSize="14"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="参数值：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="ParameterValueTextBox" 
                                     Padding="8,6" FontSize="14"/>
                        </Grid>

                        <Button Content="应用参数" Style="{StaticResource ModernButton}" 
                                Margin="0,16,0,0" Click="OnApplyParameter"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 批量删除 -->
            <TabItem Header="删除房间">
                <Border Style="{StaticResource CardPanel}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="危险操作" FontSize="16" FontWeight="Bold" 
                                   Foreground="#FF3B30" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="将删除所有选中的房间，此操作不可撤销！" 
                                   FontSize="14" Foreground="#FF3B30" Margin="0,0,0,16"/>

                        <TextBlock x:Name="SelectedCountText" 
                                   Text="已选中 0 间房间" FontSize="14" Margin="0,0,0,16"/>

                        <Button Content="删除选中房间" Background="#FF3B30" 
                                Style="{StaticResource ModernButton}" 
                                Click="OnDeleteRooms"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭" Style="{StaticResource SecondaryButton}" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
