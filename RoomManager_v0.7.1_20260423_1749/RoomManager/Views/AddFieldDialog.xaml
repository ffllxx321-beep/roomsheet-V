<Window x:Class="RoomManager.Views.AddFieldDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加字段" 
        Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E5EA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="" FontSize="20" Margin="0,0,8,0"/>
            <TextBlock Text="添加自定义字段" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 表单 -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}">
            <StackPanel>
                <!-- 字段名称 -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="字段名称" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding FieldName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"/>
                    <TextBlock Text="例如：负责人" FontSize="11" Foreground="#C7C7CC" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 字段类型 -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="字段类型" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,6"/>
                    <ComboBox SelectedIndex="0" 
                              SelectedItem="{Binding FieldType}"
                              Padding="12,8" FontSize="14">
                        <ComboBoxItem Content="文本"/>
                        <ComboBoxItem Content="数字"/>
                        <ComboBoxItem Content="下拉选择"/>
                        <ComboBoxItem Content="日期"/>
                        <ComboBoxItem Content="是/否"/>
                        <ComboBoxItem Content="多行文本"/>
                    </ComboBox>
                </StackPanel>

                <!-- 下拉选项（仅下拉类型显示） -->
                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="下拉选项（用逗号分隔）" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Options, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"/>
                    <TextBlock Text="例如：张三,李四,王五" FontSize="11" Foreground="#C7C7CC" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" 
                    Click="OnCancelClick" Margin="0,0,12,0"/>
            <Button Content="确定" Style="{StaticResource ModernButton}"
                    Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>
